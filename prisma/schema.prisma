// Prisma schema for Application Tracker (PostgreSQL)
// Enums are represented as string fields validated in zod, and old/new
// values are JSON-encoded strings to keep parity with previous schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applicationDrafts ApplicationDraft[]
  preference        UserPreference?
}

model Application {
  id              String   @id @default(cuid())
  company         String
  companyId       String?
  companyRecord   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  position        String
  listingDetails  String?
  location        String?
  workMode        String   @default("REMOTE") // REMOTE | HYBRID | ONSITE
  employmentType  String   @default("FULL_TIME") // FULL_TIME | PART_TIME | CONTRACT | INTERN | FREELANCE
  priority        String   @default("MEDIUM") // HIGH | MEDIUM | LOW
  salaryMin       Int?
  salaryMax       Int?
  targetSalaryMin Int?
  targetSalaryMax Int?
  currency        String?  @default("USD")
  source          String?  // LinkedIn, Indeed, Kariyer.net, Referral, Other...
  sourceType      String?  // JOB_BOARD | COMPANY_SITE | REFERRAL | RECRUITER | NETWORK | OTHER
  referralName    String?
  jobUrl          String?
  appliedAt       DateTime @default(now())
  status          String   @default("APPLIED") // APPLIED | SCREENING | INTERVIEW | OFFER | REJECTED | WITHDRAWN | ON_HOLD
  outcomeReason   String?  // NO_RESPONSE | ROLE_CLOSED | SALARY_MISMATCH | LOCATION_MISMATCH | SKILL_MISMATCH | FAILED_SCREEN | FAILED_INTERVIEW | ACCEPTED_OTHER | WITHDREW_BY_CHOICE | OTHER
  contactName     String?
  contactRole     String?
  contactEmail    String?
  contactPhone    String?
  contactProfileUrl String?
  resumeVersion   String?
  coverLetterVersion String?
  portfolioUrl    String?
  needsSponsorship Boolean?
  relocationPreference String? // OPEN | CONDITIONAL | NOT_OPEN
  workAuthorizationNote String?
  team            String?
  department      String?
  companySize     String?  // STARTUP | SMALL | MID_SIZE | LARGE | ENTERPRISE
  industry        String?
  applicationMethod String? // EASY_APPLY | COMPANY_ATS | REFERRAL | RECRUITER_DIRECT | EMAIL | OTHER
  timezoneOverlapHours Int?
  officeDaysPerWeek Int?
  notes           String?  // markdown
  nextStepAt      DateTime?
  nextStepNote    String?
  nextActionType  String?  // FOLLOW_UP | RECRUITER_CALL | PHONE_SCREEN | TECH_INTERVIEW | TAKE_HOME | ONSITE | OFFER_DISCUSSION | WAITING | OTHER
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tags        ApplicationTag[]
  attachments Attachment[]
  activities  ActivityEntry[]
  drafts      ApplicationDraft[]

  @@index([status])
  @@index([priority])
  @@index([companySize])
  @@index([applicationMethod])
  @@index([appliedAt])
  @@index([companyId])
}

model Company {
  id             String   @id @default(cuid())
  name           String
  normalizedName String   @unique
  legalName      String?
  aliases        String? // comma-separated
  description    String?
  tagline        String?
  foundedYear    Int?
  companyType    String? // PUBLIC | PRIVATE | NONPROFIT | GOVERNMENT | STARTUP | SUBSIDIARY | OTHER
  industry       String?
  subIndustry    String?
  companySize    String? // STARTUP | SMALL | MID_SIZE | LARGE | ENTERPRISE
  stockSymbol    String?
  parentCompany  String?

  // Location
  location        String? // primary / display
  headquarters    String?
  country         String?
  timezone        String?
  officeLocations String?

  // Online presence
  website       String?
  careersUrl    String?
  linkedinUrl   String?
  twitterUrl    String?
  githubUrl     String?
  glassdoorUrl  String?
  crunchbaseUrl String?
  blogUrl       String?
  youtubeUrl    String?

  // Business
  revenue       String?
  fundingStage  String? // SEED | SERIES_A | SERIES_B | SERIES_C | SERIES_D | LATE_STAGE | IPO | BOOTSTRAPPED | ACQUIRED | UNKNOWN
  fundingTotal  String?
  valuation     String?
  employeeCount Int?
  ceo           String?

  // Tech / Culture
  techStack       String?
  benefits        String?
  workCulture     String?
  remotePolicy    String? // FULLY_REMOTE | HYBRID | ONSITE | FLEXIBLE | UNKNOWN
  hiringStatus    String? // ACTIVELY_HIRING | LIMITED | FROZEN | UNKNOWN
  glassdoorRating Float?

  // Main contact
  mainContactName  String?
  mainContactRole  String?
  mainContactEmail String?
  mainContactPhone String?
  mainPhone        String?
  mainEmail        String?

  // Personal tracking
  rating         Int? // 1-5
  priority       String? // HIGH | MEDIUM | LOW
  trackingStatus String? // INTERESTED | RESEARCHING | APPLIED | TALKING | ARCHIVED
  pros           String?
  cons           String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications Application[]
  activities   CompanyActivityEntry[]

  @@index([name])
}

model CompanyActivityEntry {
  id        String   @id @default(cuid())
  companyId String
  type      String // CREATED | FIELD_CHANGE | NOTE_ADDED | BOOTSTRAPPED_FROM_APPLICATION | LINKED_APPLICATION | UNLINKED_APPLICATION
  field     String?
  oldValue  String?
  newValue  String?
  comment   String?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([createdAt])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("gray")
  createdAt DateTime @default(now())

  applications ApplicationTag[]
}

model SourceOption {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model CurrencyOption {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  symbol        String?
  isDefault     Boolean  @default(false)
  usdRate       Decimal? @db.Decimal(18, 6)
  rateSource    String?
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ApplicationTag {
  applicationId String
  tagId         String

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([applicationId, tagId])
  @@index([tagId])
}

model Attachment {
  id            String   @id @default(cuid())
  applicationId String
  fileName      String
  mimeType      String
  size          Int
  storagePath   String
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model ActivityEntry {
  id            String   @id @default(cuid())
  applicationId String
  type          String   // CREATED | FIELD_CHANGE | STATUS_CHANGE | COMMENT | ATTACHMENT_ADDED | ATTACHMENT_REMOVED
  field         String?
  oldValue      String?  // JSON-encoded
  newValue      String?  // JSON-encoded
  comment       String?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
  @@index([createdAt])
}

model ApplicationDraft {
  id                       String   @id @default(cuid())
  userId                   String
  applicationId            String?
  mode                     String   // CREATE | EDIT
  label                    String?
  payload                  Json
  schemaVersion            Int      @default(1)
  baseApplicationUpdatedAt DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([userId, mode])
  @@index([userId, applicationId])
  @@index([updatedAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  key       String
  email     String
  ipAddress String?
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([key, createdAt])
  @@index([createdAt])
}

model UserPreference {
  id                  String   @id @default(cuid())
  userId              String   @unique
  locale              String   @default("en")
  timeZone            String   @default("UTC")
  defaultCurrencyCode String?  @default("USD")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
