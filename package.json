{
	"name": "application-tracker",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"typecheck": "tsc --noEmit",
		"format:md": "prettier --ignore-path .gitignore --write \"**/*.md\"",
		"format": "biome format --write && bun run format:md",
		"lint": "biome lint --write --unsafe",
		"check:md": "prettier --ignore-path .gitignore --check \"**/*.md\"",
		"check": "biome check --write --unsafe && bun run check:md",
		"db:migrate": "prisma migrate dev",
		"db:seed": "tsx prisma/seed.ts",
		"db:studio": "prisma studio",
		"db:reset": "prisma migrate reset",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:unit": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e:server": "tsx test/e2e/web-server.ts",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	},
	"dependencies": {
		"@auth/prisma-adapter": "^2.11.2",
		"@aws-sdk/client-s3": "^3.1035.0",
		"@hookform/resolvers": "^5.2.2",
		"@prisma/adapter-pg": "^7.8.0",
		"@radix-ui/react-icons": "^1.3.2",
		"@radix-ui/themes": "^3.3.0",
		"bcryptjs": "^3.0.3",
		"date-fns": "^4.1.0",
		"next": "16.2.4",
		"next-auth": "^5.0.0-beta.31",
		"next-intl": "^4.9.1",
		"pg": "^8.20.0",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-hook-form": "^7.73.1",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@playwright/test": "^1.59.1",
		"@prisma/client": "^7.8.0",
		"@prisma/config": "^7.8.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/bcryptjs": "^3.0.0",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.5",
		"jsdom": "^29.0.2",
		"prettier": "^3.8.3",
		"prisma": "^7.8.0",
		"testcontainers": "^11.14.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"ignoreScripts": [
		"sharp",
		"unrs-resolver"
	],
	"trustedDependencies": [
		"@prisma/client",
		"@prisma/engines",
		"esbuild",
		"prisma",
		"sharp",
		"unrs-resolver"
	]
}
