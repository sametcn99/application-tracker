# Database
POSTGRES_USER="appuser"
POSTGRES_PASSWORD="change-me-postgres-password"
POSTGRES_DB="appdb"
DATABASE_URL="postgresql://appuser:change-me-postgres-password@postgres:5432/appdb?schema=public"

# Next-Auth
AUTH_SECRET="change-me-to-a-long-random-string"

# Seed admin user
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Change-me-123!"
ADMIN_NAME="Admin"

# S3 / MinIO
MINIO_ROOT_USER="change-me-minio-user"
MINIO_ROOT_PASSWORD="change-me-minio-password"
S3_ACCESS_KEY_ID="change-me-minio-user"
S3_SECRET_ACCESS_KEY="change-me-minio-password"