# Database (postgres in docker-compose, override for external db)
DATABASE_URL="postgresql://appuser:apppassword@localhost:5432/appdb?schema=public"

# Next-Auth
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_TRUST_HOST=true

# Seed admin user
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Change-me-123!"
ADMIN_NAME="Admin"

# Uploads
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_MIME_TYPES="application/pdf,text/plain,image/png,image/jpeg"
UPLOAD_ALLOWED_EXTENSIONS=".pdf,.txt,.png,.jpg,.jpeg"
HEALTH_ENDPOINT_PUBLIC=false

# S3 / MinIO
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="attachments"
S3_FORCE_PATH_STYLE="true"